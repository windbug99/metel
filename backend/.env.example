# ============================================================
# metel backend env (Overhaul Phase 1 baseline)
# Last updated: 2026-03-03
# ============================================================

# 1) Core (required)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 2) Notion OAuth (required for server startup + Phase 1)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=
NOTION_STATE_SECRET=

# 3) Linear OAuth (required for Phase 1 Linear integration)
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_REDIRECT_URI=
LINEAR_STATE_SECRET=

# 4) Security / runtime (recommended)
# Optional token encryption key. If empty, token is stored as plain text.
NOTION_TOKEN_ENCRYPTION_KEY=
# Optional; used for Notion API version header.
NOTION_API_VERSION=2025-09-03
# Optional; create-page fallback parent.
NOTION_DEFAULT_PARENT_PAGE_ID=

# 5) Web / CORS
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://metel-frontend.vercel.app

# 6) Validation
TOOL_SPECS_VALIDATE_ON_STARTUP=true

# 7) Phase 2 safe execution (retry)
MCP_RETRY_MAX_RETRIES=1
MCP_RETRY_BACKOFF_MS=250
MCP_QUOTA_PER_KEY_DAILY=0
MCP_QUOTA_PER_USER_DAILY=0
WEBHOOK_RETRY_MAX_RETRIES=5
WEBHOOK_RETRY_BASE_BACKOFF_SECONDS=30
WEBHOOK_RETRY_MAX_BACKOFF_SECONDS=900

# 8) Phase 3 full-check automation (optional)
# Used by backend/scripts/run_phase3_full_check.sh and related scripts.
RUN_MCP_SMOKE=0
RUN_POLICY_SCENARIOS=0
RUN_DASHBOARD_CONSISTENCY=0
RUN_STRICT_HIGH_RISK=1

# ------------------------------------------------------------
# Notes
# - Google/Spotify/Telegram/legacy rollout env vars are intentionally
#   omitted from Phase 1 baseline.
# - Claude Desktop MCP bridge uses its own env block in
#   claude_desktop_config.json:
#   API_BASE_URL, API_KEY, BRIDGE_DEBUG
# ------------------------------------------------------------
